<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerDeposit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/btn_back"
            android:background="@drawable/btn_circle_bg"
            android:contentDescription="Kembali"
            android:padding="8dp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Deposit"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorHeaderTitle"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/dividerDeposit"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerDeposit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Card ringkasan total -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRingkasan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/colorSurface"
        app:layout_constraintTop_toBottomOf="@id/dividerDeposit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL DEPOSIT"
                    android:textSize="10sp"
                    android:textColor="@color/colorInputHint"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvTotalDeposit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorHeaderTitle"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Garis pembatas tengah -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/colorDivider"
                android:layout_marginVertical="4dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL SISA"
                    android:textSize="10sp"
                    android:textColor="@color/colorInputHint"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvTotalSisa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorInputText"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- RecyclerView daftar deposit -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDeposit"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="80dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardRingkasan"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tombol tambah deposit -->
    <Button
        android:id="@+id/btnTambahDeposit"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:text="+ Tambah Deposit"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/colorTotalValue"
        android:backgroundTint="@color/colorCardTotal"
        android:stateListAnimator="@null"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>