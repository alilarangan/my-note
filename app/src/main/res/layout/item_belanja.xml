<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Keterangan + tanggal -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvKeteranganBelanja"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/colorHeaderTitle"/>

            <TextView
                android:id="@+id/tvTanggalBelanja"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/colorInputHint"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Harga -->
        <TextView
            android:id="@+id/tvJumlahBelanja"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/colorHeaderTitle"
            android:layout_marginEnd="12dp"/>

        <!-- Tombol edit -->
        <TextView
            android:id="@+id/btnEditBelanja"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:padding="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Tombol hapus -->
        <TextView
            android:id="@+id/btnHapusBelanja"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑"
            android:textSize="14sp"
            android:textColor="@color/colorAccent"
            android:padding="4dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>