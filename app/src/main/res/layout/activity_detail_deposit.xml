<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBackDetail"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/btn_back"
            android:background="@drawable/btn_circle_bg"
            android:contentDescription="Kembali"
            android:padding="8dp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Detail Deposit"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/colorHeaderTitle"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/dividerDetail"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scroll area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="72dp"
        app:layout_constraintTop_toBottomOf="@id/dividerDetail"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card info header deposit -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorCardTotal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvNamaDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTotalValue"/>

                    <TextView
                        android:id="@+id/tvDepositDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#88FFFFFF"
                        android:layout_marginTop="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:id="@+id/tvSisaDetail"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorTotalValue"/>

                        <Button
                            android:id="@+id/btnEditHeader"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Edit"
                            android:textSize="12sp"
                            android:textColor="@color/colorCardTotal"
                            android:backgroundTint="@color/colorTotalValue"
                            style="@style/Widget.MaterialComponents.Button"
                            app:cornerRadius="10dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTotalPakai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#88FFFFFF"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Label daftar belanja -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daftar Belanja"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorHeaderTitle"
                android:layout_marginBottom="8dp"/>

            <!-- RecyclerView item belanja -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBelanja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Tombol tambah belanja -->
    <Button
        android:id="@+id/btnTambahBelanja"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:text="+ Tambah Belanja"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/colorTotalValue"
        android:backgroundTint="@color/colorCardTotal"
        android:stateListAnimator="@null"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>